# =========================
# Cloudflare DNS API 憑證
# =========================
# 從 Cloudflare Dashboard → API Tokens 獲取
CF_Token=your_cloudflare_api_token_here
CF_Account_ID=your_cloudflare_account_id_here

# =========================
# 其他 DNS 服務商（按需啟用）
# =========================
# 阿里雲 DNS
# Ali_Key=your_ali_key_here
# Ali_Secret=your_ali_secret_here

# DNSPod (騰訊雲)
# DP_Id=your_dnspod_id_here
# DP_Key=your_dnspod_key_here
